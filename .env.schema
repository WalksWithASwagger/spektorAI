# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
#
# @defaultRequired=infer @defaultSensitive=false
# ----------

# Required for cloud transcription and OpenAI helper calls.
# @sensitive @optional
OPENAI_API_KEY=

# Recommended default writing provider.
# @sensitive @optional
ANTHROPIC_API_KEY=

# Required only when saving to Notion.
# @sensitive @optional
NOTION_API_KEY=
# @optional
NOTION_DATABASE_ID=

# Required only for image generation.
# @sensitive @optional
GOOGLE_API_KEY=

# Required only for docker-compose services mode.
# @sensitive @optional
SERVICE_TOKEN=

# Optional deployment/runtime switches.
# @optional @example="direct"
DEPLOY_MODE=direct
# @optional @example="openai"
TRANSCRIPTION_BACKEND=openai
# @optional @example="size"
CHUNKER=size
# @optional @example=".cache"
WHISPERFORGE_CACHE_DIR=.cache
# @optional @example="INFO"
WHISPERFORGE_LOG_LEVEL=INFO
