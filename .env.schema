# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
#
# @defaultRequired=infer @defaultSensitive=false
# ----------

# Provider credentials.
# @sensitive @optional
OPENAI_API_KEY=
# @sensitive @optional
ANTHROPIC_API_KEY=
# @sensitive @optional
NOTION_API_KEY=
# @sensitive @optional
NOTION_DATABASE_ID=
# @sensitive @optional
GOOGLE_API_KEY=
# @sensitive @optional
SERVICE_TOKEN=
# @sensitive @optional
LINEAR_API_KEY=
# @sensitive @optional
WHISPERX_HF_TOKEN=
# @sensitive @optional
HF_TOKEN=

# Runtime and service routing.
# @optional @example="direct"
DEPLOY_MODE=direct
# @optional
TRANSCRIPTION_URL=http://transcription:8000
# @optional
PROCESSING_URL=http://processing:8000
# @optional
STORAGE_URL=http://storage:8000

# Implemented provider and transcription configuration.
# @optional
OLLAMA_BASE_URL=http://localhost:11434/v1
# @optional @example="openai"
TRANSCRIPTION_BACKEND=openai
# @optional @example="size"
CHUNKER=size
# @optional
WHISPER_MODEL=gpt-4o-mini-transcribe
# @optional
MLX_WHISPER_MODEL=mlx-community/whisper-medium-mlx
# @sensitive @optional
WHISPER_CPP_MODEL=
# @optional
WHISPERX_MODEL=small
# @optional
WHISPERX_DEVICE=cpu
# @optional
WHISPERX_COMPUTE=default
# @optional
WHISPERX_DIARIZATION=

# Local app behavior.
# @optional @example=".cache"
WHISPERFORGE_CACHE_DIR=.cache
# @optional
WHISPERFORGE_CACHE=
# @optional @example="INFO"
WHISPERFORGE_LOG_LEVEL=INFO
# @sensitive @optional
WHISPERFORGE_LOG_FILE=
# @optional
WHISPERFORGE_DISCOVER_OLLAMA=1
# @optional
WF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# @optional @auditIgnore
WF_RAG=
# @optional
WF_RAG_TOPK=5
# @optional
WF_RAG_THRESHOLD=25

# Approval-gated handoff routing.
# @optional
WHISPERFORGE_HANDOFF_DRY_RUN=
# @sensitive @optional
WHISPERFORGE_HANDOFF_GITHUB_REPO=
# @sensitive @optional
WHISPERFORGE_HANDOFF_LINEAR_TEAM_ID=
# @sensitive @optional
WHISPERFORGE_HANDOFF_FOLLOWUP_QUEUE_PATH=
# @sensitive @optional
WHISPERFORGE_HANDOFF_NOTION_DRAFT_DIR=

# Credential-free browser and fixture checks.
# @optional
BROWSER_E2E_PORT=8602
# @optional
BROWSER_E2E_FRESH_PORT=
# @sensitive @optional @auditIgnore
WHISPERFORGE_E2E_FIXTURE_PATH=

# Agentic development controls.
# @optional
AGENTIC_PROVIDER=noop
# @sensitive @optional @auditIgnore
AGENTIC_PROVIDER_COMMAND=
# @optional
LOOP_PAUSED=
# @sensitive @optional
ISSUE_BODY=
# @optional
ISSUE_LABELS=

# Candidate providers stay outside this contract until a runtime integration exists.
